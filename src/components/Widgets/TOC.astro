---
import type { MarkdownHeading } from 'astro'
import TocIcon from '@/assets/icons/toc-icon.svg'
import { ui } from '@/i18n/ui'
import { getPageInfo } from '@/utils/page'

interface Props {
  headings: MarkdownHeading[]
}

const { currentLang } = getPageInfo(Astro.url.pathname)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}

const { headings = [] } = Astro.props
const filteredHeadings = headings.filter(heading => heading.depth >= 2 && heading.depth <= 4)
---

{filteredHeadings.length > 0 && (
  <details
    id="toc-container"
    data-toc
    open
    class="mb-6 uno-round-border bg-secondary/5 2xl:(fixed left-0 top-44.5 max-w-[min(calc(50vw-38rem),13rem)] border-none bg-secondary/0)"
  >
    <summary
      id="toc-summary"
      class="relative h-12 w-full 2xl:(c-secondary/60 transition-colors ease-out hover:c-primary)"
    >
      <span id="toc-mobile-text">
        {currentUI.toc}
      </span>

      <TocIcon
        id="toc-desktop-icon"
        aria-hidden="true"
        class="ml-4 hidden aspect-square w-4.2 2xl:(mt-4 block origin-center active:scale-90!)"
        fill="currentColor"
      />
    </summary>

    <div id="toc-accordion-wrapper">
      <nav
        id="toc-accordion-content"
        aria-label={currentUI.toc}
      >
        <ul id="toc-links-list">
          {filteredHeadings.map(heading => (
            <li
              class:list={{
                'ml-0': heading.depth === 2,
                'ml-4': heading.depth === 3,
                'ml-8': heading.depth === 4,
              }}
            >
              <a
                href={`#${heading.slug}`}
                data-toc-link
                data-heading-slug={heading.slug}
                class:list={[
                  { 'no-heti toc-links-h2': heading.depth === 2 },
                  { 'no-heti toc-links-h3': heading.depth === 3 },
                  { 'no-heti toc-links-h4': heading.depth === 4 },
                ]}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </details>
)}

<script>
const desktopMedia = window.matchMedia('(min-width: 1536px)')
const reducedMotionMedia = window.matchMedia('(prefers-reduced-motion: reduce)')

let cleanupToc = () => {}

function scrollActiveLinkIntoView(activeLink: HTMLElement | null) {
  if (!activeLink || !desktopMedia.matches) {
    return
  }

  activeLink.scrollIntoView({
    behavior: reducedMotionMedia.matches ? 'auto' : 'smooth',
    block: 'nearest',
  })
}

function resolveActiveHeadingId(headings: HTMLElement[]) {
  if (headings.length === 0) {
    return ''
  }

  const threshold = Math.max(108, window.innerHeight * 0.2)
  let activeHeading = headings[0]

  for (const heading of headings) {
    if (heading.getBoundingClientRect().top <= threshold) {
      activeHeading = heading
      continue
    }

    break
  }

  if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 8) {
    return headings.at(-1)?.id ?? activeHeading.id
  }

  return activeHeading.id
}

function setupToc() {
  cleanupToc()

  const tocEl = document.querySelector('[data-toc]')
  const tocListEl = document.getElementById('toc-links-list')
  if (!(tocEl instanceof HTMLDetailsElement) || !(tocListEl instanceof HTMLElement)) {
    return
  }

  const toc = tocEl
  const tocList = tocListEl
  const links: HTMLAnchorElement[] = Array.from(tocList.querySelectorAll('a[data-toc-link]'))
  const headings: HTMLElement[] = links
    .map((link) => {
      const slug = link.getAttribute('data-heading-slug')
      if (!slug) {
        return null
      }

      return document.getElementById(slug)
    })
    .filter(heading => heading instanceof HTMLElement)

  if (headings.length === 0) {
    return
  }

  let frameId = 0
  let lastActiveSlug = ''

  function setDesktopState() {
    toc.open = desktopMedia.matches
  }

  function updateActiveLink() {
    frameId = 0

    const activeSlug = resolveActiveHeadingId(headings)
    if (!activeSlug || activeSlug === lastActiveSlug) {
      return
    }

    let nextActiveLink: HTMLAnchorElement | null = null

    for (const link of links) {
      const isActive = link.getAttribute('data-heading-slug') === activeSlug
      link.toggleAttribute('data-active', isActive)

      if (isActive) {
        link.setAttribute('aria-current', 'location')
        nextActiveLink = link
      }
      else {
        link.removeAttribute('aria-current')
      }
    }

    scrollActiveLinkIntoView(nextActiveLink)
    lastActiveSlug = activeSlug
  }

  function queueActiveLinkUpdate() {
    if (frameId) {
      return
    }

    frameId = window.requestAnimationFrame(updateActiveLink)
  }

  function handleMediaChange() {
    setDesktopState()
    queueActiveLinkUpdate()
  }

  function handleTocClick(event: MouseEvent) {
    const link = event.target instanceof Element
      ? event.target.closest('[data-toc-link]')
      : null

    if (!link || desktopMedia.matches) {
      return
    }

    window.requestAnimationFrame(() => {
      toc.open = false
    })
  }

  setDesktopState()
  queueActiveLinkUpdate()

  window.addEventListener('scroll', queueActiveLinkUpdate, { passive: true })
  window.addEventListener('resize', queueActiveLinkUpdate)
  desktopMedia.addEventListener('change', handleMediaChange)
  toc.addEventListener('click', handleTocClick)

  cleanupToc = () => {
    window.removeEventListener('scroll', queueActiveLinkUpdate)
    window.removeEventListener('resize', queueActiveLinkUpdate)
    desktopMedia.removeEventListener('change', handleMediaChange)
    toc.removeEventListener('click', handleTocClick)

    if (frameId) {
      window.cancelAnimationFrame(frameId)
      frameId = 0
    }
  }
}

document.addEventListener('astro:page-load', setupToc)
document.addEventListener('astro:before-swap', cleanupToc)
</script>
